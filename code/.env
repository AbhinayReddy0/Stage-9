# Stage 9 — environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your values.  Never commit real credentials.
# All Stage 9 code reads these variables (and only these) via infrastructure/config.py.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test
DB_USER=test
DB_PASSWORD=test
DB_SSLMODE=disable
DB_CONNECT_TIMEOUT=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=20

# ── Application ───────────────────────────────────────────────────────────────
# Number of parallel threads used by the planning handler (Sub-Stage 9.1).
STAGE9_PLANNING_THREADS=16

# Set to true only when you intentionally need force_release on a RunLock.
STAGE9_ALLOW_FORCE_RELEASE=false

# Absolute path to the project root; used by tests to locate fixture files.
STAGE9_PROJECT_ROOT=M:/stage_9/code

# Set to true (or 1) to run Redis/Postgres integration tests.
RUN_INTEGRATION_TESTS=true
